{
  "name": "smartvex-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && uvicorn main:app --reload",
    "dev:worker": "cd backend && celery -A workers.celery_app worker --loglevel=info",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:worker\"",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install --prefix frontend && pip install -r backend/requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "next": "14.x"
  }
}
